# Copy this file to .env and fill in your values
PORT=3002
MONGO_URI=mongodb://127.0.0.1:27017/hackathons
JWT_SECRET=change_this_to_a_long_random_string
CLIENT_URLS=http://localhost:5173,https://hackathons.engimind.cloud

# Set to "true" to run the scraper cron automatically when the server starts
ENABLE_CRON=false
