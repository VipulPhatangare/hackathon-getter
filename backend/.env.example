# Copy this file to .env and fill in your values
PORT=3002
MONGO_URI=mongodb://127.0.0.1:27017/hackathons
JWT_SECRET=change_this_to_a_long_random_string
CLIENT_URLS=http://localhost:5173,https://hackathons.engimind.cloud

# Comma-separated emails auto-promoted to admin on register/login.
ADMIN_EMAILS=you@example.com

# Gemini Flash 2.5 — get a free key at https://aistudio.google.com/
# Can also be set/overridden from the admin dashboard (stored in DB).
GEMINI_API_KEY=your_gemini_api_key_here

# Default legitimacy threshold (also editable from the admin dashboard).
LEGITIMACY_MIN=4

# Shared API key for POST /api/hackathons/external/all (server-to-server access).
# Default is base64 of "hackathons_for_synthomind"; override here or in the dashboard.
EXTERNAL_API_KEY=aGFja2F0aG9uc19mb3Jfc3ludGhvbWluZA==
